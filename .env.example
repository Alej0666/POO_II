# Configuración de Base de Datos

# ============================================
# SQLite (desarrollo local - por defecto)
# ============================================
DATABASE_URL=sqlite+aiosqlite:///./taskflow.db

# ============================================
# PostgreSQL (producción)
# ============================================
# DATABASE_URL=postgresql+psycopg://usuario:password@localhost:5432/taskflow

# ============================================
# PostgreSQL (con variables de entorno)
# ============================================
# DATABASE_URL=postgresql+psycopg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
# DB_USER=postgres
# DB_PASSWORD=tu_password_aqui
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=taskflow

# ============================================
# Configuración de Seguridad JWT
# ============================================
SECRET_KEY=tu-clave-secreta-super-segura-en-produccion-usa-env
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# Configuración de la Aplicación
# ============================================
DEBUG=False
ENVIRONMENT=development
